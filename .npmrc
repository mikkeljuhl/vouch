# Pin install registry to public npm so a contributor's ~/.npmrc (e.g. a
# corporate Artifactory mirror that requires auth) can't leak into bun.lock.
# Without this, lockfile URLs point at whatever registry the local environment
# happens to use — and CI on this public repo can't authenticate against
# private mirrors (every package install fails with 401). Project .npmrc beats
# user .npmrc per the standard npm/Bun rc precedence.
registry=https://registry.npmjs.org/
