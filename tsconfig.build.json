{
  // Declaration-only build (DESIGN.md §7). Bun runs the TS source directly, so
  // there is NO runtime build — this emits ONLY `.d.ts` for consumers' tsc/IDE,
  // so they resolve our types without dragging our raw `src/*.ts` into their
  // program (skipLibCheck doesn't skip `.ts`). Generated into `dist/` (gitignored).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  // Lib only — never emit declarations for tests or the CLI.
  "include": ["src"]
}
