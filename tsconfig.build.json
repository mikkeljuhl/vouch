{
  // Dual emit (JS + .d.ts) into `dist/` for Node consumers (the `default` export
  // condition points here). Bun still imports `src/*.ts` directly via the `bun`
  // export condition, so no runtime build is needed for Bun. Source imports use
  // `.js` extensions so the emitted JS is a valid Node ESM module graph;
  // TypeScript resolves the `.js` specifiers to their `.ts` siblings at compile
  // time, and Bun does the same at runtime.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  // Lib only — never emit JS/declarations for tests or the CLI.
  "include": ["src"]
}
