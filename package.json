{
  "name": "@mikkeljuhl/vouch",
  "version": "0.3.1",
  "license": "MIT",
  "description": "Code-authored API test framework for Bun: a fluent builder that sends real requests and asserts on responses.",
  "author": "Mikkel Juhl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikkeljuhl/vouch.git"
  },
  "homepage": "https://github.com/mikkeljuhl/vouch#readme",
  "bugs": "https://github.com/mikkeljuhl/vouch/issues",
  "keywords": [
    "api",
    "testing",
    "e2e",
    "bun",
    "http",
    "fetch"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "sideEffects": false,
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "cli",
    "dist"
  ],
  "bin": {
    "vouch": "cli/vouch.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:ci": "bun test --reporter=junit --reporter-outfile=reports/junit.xml",
    "typecheck": "tsc --noEmit",
    "gen:version": "bun scripts/gen-version.mjs",
    "build:types": "tsc -p tsconfig.build.json",
    "prepare": "bun scripts/gen-version.mjs && tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
