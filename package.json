{
  "name": "@mikkeljuhl/vouch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "cli",
    "dist"
  ],
  "bin": {
    "vouch": "./cli/vouch.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:ci": "bun test --reporter=junit --reporter-outfile=reports/junit.xml",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
